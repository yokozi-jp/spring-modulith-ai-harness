# 環境変数テンプレート
# ローカル開発: cp .env.example .env して使用（.env は .gitignore 済み）
# 本番: 環境変数を直接設定する

# --- DB ---
DATASOURCE_URL=jdbc:postgresql://postgres:5432/demo
DATASOURCE_USERNAME=demo
DATASOURCE_PASSWORD=demo
DB_SCHEMA=demo

# --- OAuth2 ---
# OAUTH2_AUTHORIZATION_URI: ブラウザからアクセスする URL (localhost)
# OAUTH2_TOKEN_URI / OAUTH2_JWK_SET_URI / OAUTH2_USERINFO_URI: バックエンドから Keycloak への内部通信 (keycloak)
OAUTH2_AUTHORIZATION_URI=http://localhost:8080/realms/demo/protocol/openid-connect/auth
OAUTH2_TOKEN_URI=http://keycloak:8080/realms/demo/protocol/openid-connect/token
OAUTH2_JWK_SET_URI=http://keycloak:8080/realms/demo/protocol/openid-connect/certs
OAUTH2_USERINFO_URI=http://keycloak:8080/realms/demo/protocol/openid-connect/userinfo
OAUTH2_CLIENT_SECRET=demo-app-secret

# --- Redis ---
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SESSION_COOKIE_SECURE=false

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://grafana-lgtm:4318/v1/traces
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://grafana-lgtm:4318/v1/logs
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://grafana-lgtm:4318/v1/metrics
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0

# --- App ---
SERVER_PORT=18080
TZ=UTC
ACTUATOR_USERNAME=admin
ACTUATOR_PASSWORD=admin

# --- SpringDoc ---
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true

# --- DevTools ---
SPRING_DEVTOOLS_RESTART_POLL_INTERVAL=2s
SPRING_DEVTOOLS_RESTART_QUIET_PERIOD=1s

# --- Logging ---
LOGGING_STRUCTURED_FORMAT_CONSOLE=ecs
LOGGING_LEVEL_COM_EXAMPLE_DEMO=debug
LOGGING_LEVEL_ORG_JOOQ=debug
