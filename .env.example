# ローカル開発用環境変数テンプレート
# このファイルを .env にコピーして使用する: cp .env.example .env
# .env は .gitignore に含まれるためコミットされない。

# --- bootRun / アプリ共通 ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/demo
SPRING_DATASOURCE_USERNAME=demo
SPRING_DATASOURCE_PASSWORD=demo
OAUTH2_ISSUER_URI=http://localhost:8080/realms/demo

# --- アプリコンテナ用（docker compose --profile app）---
# DB/OAuth2 の URL は compose.yaml の environment で Docker ネットワーク内アドレスに上書きされる。
APP_PORT=8081
DEBUG_PORT=5005
