# 本番デプロイで設定が必要な環境変数
# ローカル開発（bootRun）や CI（./gradlew check）では不要。
# bootRun: application-default.yaml の固定値 + spring-boot-docker-compose の自動注入で完結
# CI: test/resources/application-default.yaml のダミー値 + Testcontainers の動的注入で完結

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/demo
SPRING_DATASOURCE_USERNAME=demo
SPRING_DATASOURCE_PASSWORD=demo
OAUTH2_ISSUER_URI=http://localhost:8080/realms/demo
DB_SCHEMA=public
