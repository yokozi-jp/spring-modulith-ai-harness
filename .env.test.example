# テスト用環境変数
# コンテナ内実行: docker compose -f compose-test.yaml run --rm backend-test

# --- DB ---
DATASOURCE_URL=jdbc:postgresql://postgres-test:5432/demo
DATASOURCE_USERNAME=demo
DATASOURCE_PASSWORD=demo
DB_SCHEMA=demo

# --- OAuth2 ---
OAUTH2_AUTHORIZATION_URI=http://keycloak-test:8080/realms/demo/protocol/openid-connect/auth
OAUTH2_TOKEN_URI=http://keycloak-test:8080/realms/demo/protocol/openid-connect/token
OAUTH2_JWK_SET_URI=http://keycloak-test:8080/realms/demo/protocol/openid-connect/certs
OAUTH2_USERINFO_URI=http://keycloak-test:8080/realms/demo/protocol/openid-connect/userinfo
OAUTH2_CLIENT_SECRET=demo-app-secret

# --- Redis ---
SPRING_DATA_REDIS_HOST=redis-test
SPRING_DATA_REDIS_PORT=6379
SESSION_COOKIE_SECURE=false

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://grafana-lgtm-test:4318/v1/traces
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://grafana-lgtm-test:4318/v1/logs
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://grafana-lgtm-test:4318/v1/metrics
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0

# --- App ---
SERVER_PORT=18080
TZ=UTC
ACTUATOR_USERNAME=admin
ACTUATOR_PASSWORD=admin

# --- SpringDoc ---
SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false

# --- DevTools ---
SPRING_DEVTOOLS_RESTART_POLL_INTERVAL=2s
SPRING_DEVTOOLS_RESTART_QUIET_PERIOD=1s

# --- Logging ---
LOGGING_STRUCTURED_FORMAT_CONSOLE=
LOGGING_LEVEL_COM_EXAMPLE_DEMO=debug
LOGGING_LEVEL_ORG_JOOQ=debug
