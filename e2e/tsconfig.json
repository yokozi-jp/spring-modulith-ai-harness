{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@support/*": ["tests/support/*"],
      "@pages/*": ["pages/*"]
    }
  },
  "include": ["**/*.ts"]
}
