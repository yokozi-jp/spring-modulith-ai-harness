{
  "$schema": "",
  "name": "default",
  "description": "The default agent for Kiro CLI",
  "prompt": "# Kiro CLI Default Agent\n\nYou are the default Kiro CLI agent, bringing the power of AI-assisted development directly to the user's terminal. You help with coding tasks, system operations, AWS management, and development workflows.\n",
  "welcomeMessage": null,
  "tools": ["*"],
  "toolAliases": {},
  "toolsSettings": null,
  "toolSchema": null,
  "hooks": {
    "agentSpawn": [
      {
        "command": ".kiro/hooks/frontend-context.sh",
        "timeout_ms": 5000
      }
    ],
    "preToolUse": [
      {
        "matcher": "write",
        "command": ".kiro/hooks/frontend-write-guard.sh",
        "timeout_ms": 5000
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": ".kiro/hooks/frontend-test-prompt.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/orval-regen-prompt.sh",
        "timeout_ms": 5000
      }
    ],
    "stop": [
      {
        "command": ".kiro/hooks/frontend-lint-check.sh",
        "timeout_ms": 15000
      }
    ]
  },
  "mcpServers": {},
  "useLegacyMcpJson": true,
  "resources": [
    "file://AGENTS.md",
    "file://README.md",
    "skill://.kiro/skills/*/SKILL.md",
    "skill://~/.kiro/skills/*/SKILL.md",
    "file://.kiro/steering/**/*.md"
  ],
  "allowedTools": [],
  "model": "claude-opus-4.6"
}
